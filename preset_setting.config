[说明]
; 每个 preset 支持：
;   region        -> 价格读取区域
;   price_field   -> 价格字段（buy/sell/average）
;   volume_region -> 体积读取区域（固定读取 volume 字段，不会回退到 jita）
;
; 示例（船只使用 VOS 的 average + VOS volume）：
; [ships_preset]
; region = vale_of_the_silent
; price_field = average
; volume_region = vale_of_the_silent

[blueprints_preset]
region = jita
price_field = buy
volume_region = jita

[ships_preset]
region = jita
price_field = buy
volume_region = jita

[modules_preset]
region = jita
price_field = buy
volume_region = jita

[rigs_preset]
region = jita
price_field = buy
volume_region = jita

[materials_preset]
region = jita
price_field = buy
volume_region = jita

[reactions_preset]
region = jita
price_field = buy
volume_region = jita

[components_preset]
region = jita
price_field = buy
volume_region = jita
